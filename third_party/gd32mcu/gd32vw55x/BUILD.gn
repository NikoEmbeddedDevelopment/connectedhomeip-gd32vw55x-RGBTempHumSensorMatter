import("//build_overrides/gd32vw55x.gni")
import("${gd32vw55x_sdk_build_root}/gd32vw55x_sdk.gni")

import("//build_overrides/mbedtls.gni")
import("${mbedtls_root}/mbedtls.gni")

declare_args() {
  # Build target to use for gd32w515 SDK. Use this to set global SDK defines.
  gd32vw55x_target_project = ""

  gd32vw55x_target_project_mbl = ""

}

assert(gd32vw55x_target_project != "", "gd32vw55x_target_project must be specified")

group("gd32vw55x_sdk") {
  public_deps = [ gd32vw55x_target_project ]
}

group("gd32vw55x_sdk_mbl") {
  public_deps = [ gd32vw55x_target_project_mbl ]
}
