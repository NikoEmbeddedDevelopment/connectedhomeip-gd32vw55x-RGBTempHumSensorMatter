import("//build_overrides/chip.gni")


import("${chip_root}/build/config/compiler/compiler.gni") ####


import("//build_overrides/gd32vw55x.gni")
import("//build_overrides/mbedtls.gni")
import("${chip_root}/src/lib/lib.gni")
import("${chip_root}/src/platform/device.gni")
import("gd32vw55x_board.gni")


assert(gd32vw55x_sdk_root != "", "gd32vw55x_sdk_root must be specified")

declare_args() {
  gd32vw55x_wpas_lib = true
  gd32vw55x_mbedtls_sw = true
}

# Defines an gd32vw55x SDK build target.
#
# Parameters:
#   sources - The sources files to build.
#
template("gd32vw55x_sdk") {
  if (defined(invoker.gd32vw55x_sdk_root)) {
    gd32vw55x_sdk_root = invoker.gd32vw55x_sdk_root
  }

  assert(gd32vw55x_sdk_root != "", "gd32vw55x_sdk_root must be specified")

  if (defined(invoker.gd32vw55x_project_dir)) {
    gd32vw55x_project_dir = invoker.gd32vw55x_project_dir
  }

  if (defined(invoker.chip_enable_ota_requestor)) {
    if (invoker.chip_enable_ota_requestor) {
      chip_enable_ota_requestor = true
    }
  }

  sdk_target_name = target_name

  # While most gd32vw55x sdk includes come from the gd32vw55x_sdk_config config (in
  # BUILD.gn), this template gets instantiated by each project each of which
  # provides a few extra includes/defines. Handle those here.
  # config("project_configs") {
  config("${sdk_target_name}_config") {
    include_dirs = []
    _include_dirs = []
    defines = []
    libs = []
    cflags = []
    cflags_cc = []
    asmflags = []
    ldflags = []
    libs = []

    if (defined(invoker.include_dirs)) {
      include_dirs += invoker.include_dirs
    }
    include_dirs += [ "${gd32vw55x_project_dir}/include" ]

    if (defined(invoker.defines)) {
      defines += invoker.defines
    }


    # Treat these includes as system includes, so warnings in them are not fatal.
    _include_dirs += [
      # firmware inc
      "${gd32vw55x_sdk_root}/MSDK/plf/inc",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Include",
      "${gd32vw55x_sdk_root}/MSDK/plf/Utilities",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/arch",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/arch/boot",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/arch/ll",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/compiler",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/env_Eclipse",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/gd32vw55x",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/NMSIS/Core/Include",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/NMSIS/DSP/Include",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/NMSIS/DSP/Include/dsp",
      "${gd32vw55x_sdk_root}/MSDK/plf/src",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/reg",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/crm",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/phy",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/intc/risc-v",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/extint",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/sysctrl",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/ipc_fhost",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/dma",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/la",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/time",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/button",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/led",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/uart",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/nvds",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/rf",
      
      # LCD driver
      "${gd32vw55x_sdk_root}/MSDK/lcd/Soft_Drive",
      
      # MACSW
      "${gd32vw55x_sdk_root}/MSDK/macsw/import",
      "${gd32vw55x_sdk_root}/MSDK/macsw/config",
      "${gd32vw55x_sdk_root}/MSDK/macsw/export",

      # RTOS
      "${gd32vw55x_sdk_root}/MSDK/rtos/rtos_wrapper",
      "${gd32vw55x_sdk_root}/MSDK/rtos/rtos_mgmt",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/include",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS_port",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS_port/riscv32",
      
      # LWIP
      "${gd32vw55x_sdk_root}/MSDK/lwip/lwip-2.1.2/src/include",
      "${gd32vw55x_sdk_root}/MSDK/lwip/lwip-2.1.2/src/include/compat/posix",
      "${gd32vw55x_sdk_root}/MSDK/lwip/lwip-2.1.2/port",
      "${gd32vw55x_sdk_root}/MSDK/lwip/lwip-2.1.2/port/arch",
      "${gd32vw55x_sdk_root}/MSDK/lwip/iperf",
      "${gd32vw55x_sdk_root}/MSDK/lwip/iperf3",

      # ROM-EXPORT
      "${gd32vw55x_sdk_root}/ROM-EXPORT/bootloader",
      "${gd32vw55x_sdk_root}/ROM-EXPORT/halcomm",
      "${gd32vw55x_sdk_root}/ROM-EXPORT/symbol",

      "${gd32vw55x_sdk_root}/config",
      "${gd32vw55x_sdk_root}/MSDK/app",

      # BLE
      "${gd32vw55x_sdk_root}/MSDK/blesw/src/export/config",
      "${gd32vw55x_sdk_root}/MSDK/blesw/src/export",
      "${gd32vw55x_sdk_root}/MSDK/ble/app",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/dis",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/glp",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/hps",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/ias",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/lls",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/prox",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/sample",
      "${gd32vw55x_sdk_root}/MSDK/ble/profile/tps",
      "${gd32vw55x_sdk_root}/MSDK/util/include",

      # zcbor
      "${gd32vw55x_sdk_root}/MSDK/Third_Party/zcbor-0.6.0/include",
    ]

    #mbedtls
    if(gd32vw55x_mbedtls_sw) {
        _include_dirs += [
          #MBEDTLS v2.26.0
          "${gd32vw55x_sdk_root}/MSDK/Third_Party/mbedtls-2.26.0/include",
          "${gd32vw55x_sdk_root}/MSDK/mbedtls_config",
        ]
    } else {
        _include_dirs += [
          #MBEDTLS v2.17.0-ssl
          "${gd32vw55x_sdk_root}/MSDK/mbedtls/mbedtls-2.17.0-ssl/include",
          #MBEDTLS v2.17.0-rom
          "${gd32vw55x_sdk_root}/ROM-EXPORT/mbedtls-2.17.0-rom/include",
        ]
    }

    if(gd32vw55x_wpas_lib) {
        _include_dirs += [
          #wifi manager
          "${gd32vw55x_sdk_root}/MSDK/wifi_manager",
          "${gd32vw55x_sdk_root}/MSDK/wifi_manager/wpas",
        ]
    } else {
        _include_dirs += [
          # WPA
          "${gd32vw55x_sdk_root}/MSDK/wpa_supplicant/wpa_supplicant",
          "${gd32vw55x_sdk_root}/MSDK/wpa_supplicant/src",
          "${gd32vw55x_sdk_root}/MSDK/wpa_supplicant/src/utils",
          "${gd32vw55x_sdk_root}/MSDK/wpa_supplicant/src/crypto",
          
          #wifi manager
          "${gd32vw55x_sdk_root}/MSDK/wifi_manager",
        ]
    }

    if(gd32vw55x_wpas_lib) {
        defines += [
          "USE_STDPERIPH_DRIVER",
          "_TIMEVAL_DEFINED",
        ]
    } else {
        defines += [
          "USE_STDPERIPH_DRIVER",
          "_TIMEVAL_DEFINED",
          "CONFIG_WPA_SUPPLICANT",
        ]
    }
    
    if (chip_build_libshell) {
      defines += ["CHIP_LIB_SHELL_ENABLE"]
    }

    defines += board_defines

    if (chip_build_libshell) {  # matter shell
      defines += [ "ENABLE_CHIP_SHELL" ]
    }
    
    defines += [ "CFG_RTOS" ]
    defines += [ "MBEDTLS_CONFIG_FILE=\"rom_config.h\"" ]

    libs += [
      "${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/lib/libble.a",
      "${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/lib/librf.a",
      "${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/lib/libwifi.a",
      "${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/plf/riscv/NMSIS/Library/DSP/GCC/libnmsis_dsp_rv32imafcbp.a",
      "${gd32vw55x_sdk_build_root}/../riscv_toolchain/nuclei_riscv_newlibc_prebuilt_linux64_2022.04/gcc/riscv-nuclei-elf/lib/rv32imafcbp/ilp32f/libm.a",
    ]
    
    if (gd32vw55x_wpas_lib) {
        libs += ["${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/lib/libwpas.a"]
    }

    if (defined(invoker.cflags)) {
      cflags += invoker.cflags
    }
    cflags += [
      "-msmall-data-limit=8",
      "-mno-save-restore",
      "-fmessage-length=0",
      "-fsigned-char",
      "-Wall",
      "-Wno-error=unused-function",
      "-Wno-error=unused-but-set-variable",
      "-Wno-error=unused-variable",
      "-Wextra",
      "-Wno-unused-parameter",
      "-Wno-sign-compare",
      "-Wno-shadow",
      "-Wno-maybe-uninitialized",
      "-Wno-uninitialized",
      "-Wno-missing-braces",
      "-Wno-format-contains-nul",
      "-Wno-format-extra-args",
      "-Wno-comments",
      # "-Wno-enum-conversion",

      # "-Wno-incompatible-pointer-types",
      "-Wno-type-limits",
      "-Wno-conversion",
      "-c",
      "-mcmodel=medlow",
      "-ffunction-sections",
      "-fdata-sections",
      # "-fno-short-enums",
      # "-ffat-lto-objects",
      #" -fno-use-cxa-atexit",
      "-g",
    ]

    if (defined(invoker.cflags_cc)) {
      cflags_cc += invoker.cflags_cc
    }
    cflags_cc += [
      "-msmall-data-limit=8",
      "-mno-save-restore",
      "-c",
      "-mcmodel=medlow",
      "-march=rv32imafcbp",
      "-mabi=ilp32f",
      "-ffunction-sections",
      "-fdata-sections",
      "-fsigned-char",
      # "-ffat-lto-objects",
      # "-fno-short-enums",
      "-g",
      "-Wall",
      "-fno-rtti",
      "-fno-exceptions",
      # "-fno-use-cxa-atexit",
      "-Wno-register",
    ]

    if (defined(invoker.asmflags)) {
      asmflags += invoker.asmflags
    }
    asmflags += [
      "-c",
      "-mcmodel=medlow",
      "-ffunction-sections",
      "-fdata-sections",
     # "-ffat-lto-objects",
     # "-fno-use-cxa-atexit",
      "-g",
      "-Wall",
    ]

    if (defined(invoker.ldflags)) {
      ldflags += invoker.ldflags
    }

    if (is_debug) {
      cflags += [ "-O${optimize_debug_level}" ]
      cflags_cc += [ "-O${optimize_debug_level}" ]
      asmflags += [ "-O${optimize_debug_level}" ]
      ldflags += [ "-O${optimize_debug_level}" ]
      
    } else {
      cflags += [ "-Os" ]
      cflags_cc += [ "-Os" ]
      asmflags += [ "-Os" ]
      ldflags += [ "-Os" ]
    }

    ldflags += [
      # "-march=rv32imafcbp",
      # "-mabi=ilp32f",
      "-mcmodel=medlow",
      "-nostartfiles",
      "--specs=nano.specs",
      "--specs=nosys.specs",
      "-ffunction-sections",
      "-fdata-sections",
      # "-ffat-lto-objects",
      # "-fno-use-cxa-atexit",
      "-fno-exceptions",
      "-fno-rtti",
      "-g",
      "-Xlinker",
      "--gc-sections",
      "-u",
      "_printf_float",
      "-Wall",
      "-Wl,--gc-sections",
      # "-Wl,--just-symbols=..${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/ROM-EXPORT/symbol/rom_symbol.gcc",
      "-T..${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/MSDK/plf/riscv/env_Eclipse/gd32vw55x.lds",
    ]

    if(!gd32vw55x_mbedtls_sw) {
        ldflags += [ "-Wl,--just-symbols=..${gd32vw55x_sdk_build_root}/GD32VW55x_RELEASE_V1.0.0/ROM-EXPORT/symbol/rom_symbol.gcc" ]
    }


    # cflags += [ "-Wno-format", "-Wno-implicit-fallthrough" ]
    # cflags_cc += [ "-Wno-format", "-Wno-implicit-fallthrough" ]
    cflags += [ "-Wno-format-security", "-Wno-implicit-fallthrough" ]
    cflags_cc += [ "-Wno-format-security", "-Wno-implicit-fallthrough" ]


    # cflags_cc += [ "-std=gnu++14" ]
    # cflags_cc += [ "-std=gnu++17" ]

    # foreach(include_dir, _include_dirs) {
    #     cflags += [ "-isystem" + rebase_path(include_dir, root_build_dir) ]
    # }

    include_dirs += _include_dirs
  }

  # Add sources here
  source_set(sdk_target_name) {
    sources = []
    if (defined(invoker.sources)) {
      sources += invoker.sources
    }

    # gd32vw55x peripheral source files
    sources += [
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_adc.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_cau.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_cau_aes.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_cau_des.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_cau_tdes.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_crc.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_dbg.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_dma.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_eclic.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_efuse.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_exti.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_fmc.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_fwdgt.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_gpio.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_hau.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_hau_sha_md5.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_i2c.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_pkcau.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_pmu.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_qspi.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_rcu.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_rtc.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_spi.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_syscfg.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_timer.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_trng.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_usart.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/GD32VW55x_standard_peripheral/Source/gd32vw55x_wwdgt.c",

      "${gd32vw55x_sdk_root}/MSDK/plf/Utilities/gd32vw553h_eval.c",
    ]

    # gd32vw55x lcd driver files
    sources += [
      "${gd32vw55x_sdk_root}/MSDK/lcd/Soft_Drive/delay_ms.c",
      "${gd32vw55x_sdk_root}/MSDK/lcd/Soft_Drive/gui.c",
      "${gd32vw55x_sdk_root}/MSDK/lcd/Soft_Drive/lcd_driver.c",
      "${gd32vw55x_sdk_root}/MSDK/lcd/lcd_display.c",
    ]

    # gd32vw55x riscv driver files
    sources += [
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/env_Eclipse/entry.S",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/env_Eclipse/handlers.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/env_Eclipse/init.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/env_Eclipse/start.S",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/arch/lib/lib_hook.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/gd32vw55x/gd32vw55x_it.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/riscv/gd32vw55x/system_gd32vw55x.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/data_path/plf_data_path.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/dma/dma.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/intc/risc-v/intc.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/la/la_mem_mac.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/nvds/nvds_flash.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/sysctrl/sysctrl.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/time/systime.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/uart/ble_uart.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/uart/console_uart.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/uart/trace_uart.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/uart/uart.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/gd32vw55x_platform.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/init_rom.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/plf_assert.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/trng.c",
      "${gd32vw55x_sdk_root}/MSDK/plf/src/wakelock.c",
    ]

    #OS
    sources += [
      ###riscv
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/croutine.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/event_groups.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/list.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/queue.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/stream_buffer.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/tasks.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/timers.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/portable/Common/tickless_sleep.c",
      "${gd32vw55x_sdk_root}/MSDK/rtos/FreeRTOS/Source/portable/MemMang/heap_4.c",
