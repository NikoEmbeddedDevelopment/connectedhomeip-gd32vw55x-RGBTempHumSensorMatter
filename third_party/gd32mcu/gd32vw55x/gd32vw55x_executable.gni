  objcopy_image_format = "ihex"
  # objcopy = "riscv-none-embed-objcopy"

  riscv_toolcahin_dir = "${chip_root}/third_party/gd32mcu/riscv_toolchain/nuclei_riscv_newlibc_prebuilt_linux64_2022.04/gcc/bin"
  _tool_name_root_dir = rebase_path(riscv_toolcahin_dir)

  objcopy = "${_tool_name_root_dir}/riscv-nuclei-elf-objcopy"


  #Copy flashing dependencies to the output directory so that the output
