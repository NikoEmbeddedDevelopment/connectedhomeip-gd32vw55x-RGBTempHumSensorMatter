  #   outputs = [ "${root_out_dir}/{{source_file_part}}" ]
  # }

  # flashing_script_generator =
  #     "${chip_root}/scripts/flashing/gen_flashing_script.py"
  # flashing_script_name = output_base_name + ".flash.py"
  # flashing_options = [
  #   "gd32vw55x",
  #   "--device",
  #   "${gd32vw55x_board}",
  # ]

  flashable_executable(target_name) {
    forward_variables_from(invoker, "*")
    # data_deps = [ ":${flashing_runtime_target}" ]
  }
}

template("build_sdk_date_file") {
  if (defined(invoker.version)) {
    print(invoker.version)
  }
  action(target_name) {
    deps = []
    if (defined(invoker.deps)) {
      deps += invoker.deps
    }
    args = []
    if (defined(invoker.exec_path)) {
      args += [ "--path=${invoker.exec_path}" ]
    }
    if (defined(invoker.enable)) {
      args += [ "--enable=${invoker.enable}" ]
    }
    if (defined(invoker.prebuilts)) {
      args += [ "--prebuilts=${invoker.prebuilts}" ]
    }
    if (defined(invoker.command)) {
      args += [ "--command=${invoker.command}" ]
    }

    # external component build log
    target_dir = rebase_path("${target_out_dir}/build.log")
    args += [ "--target_dir=${target_dir}" ]
    # print(target_dir)

    # external component error log if compile failed
    out_dir = rebase_path("${root_out_dir}/error.log")
    args += [ "--out_dir=${out_dir}" ]
    script = "//build_sdk_time_file.py"

    # script = "${chip_root}/examples/lighting-app/gd32mcu/gd32vw55x/build_sdk_time_file.py"

    # script  = "${invoker.script}"
    # print(script)

    outputs = [ "$target_out_dir/${target_name}_build_sdk_time_file.txt" ]

    # print(outputs)
  }
}


