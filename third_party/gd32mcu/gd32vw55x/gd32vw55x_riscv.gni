import("gd32vw55x_board.gni")

declare_args() {
  nuclei_toolchain = true
}

if (nuclei_toolchain) {
    riscv_arch = "rv32imafcbp"
    riscv_abi = "ilp32f"
} else {
    riscv_arch = "rv32imafdc"
    riscv_abi = "ilp32d"
}
